{
  "name": "zettlink",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "run-pty run-pty.json",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "gen-types": "bash scripts/gen-types.sh",
    "deploy:dashboard": "tsx scripts/deploy-dashboard.ts",
    "deploy:site": "tsx scripts/deploy-site.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "run-pty": "^6.0.2",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
