{
  "name": "@zettlink/blog",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist",
    "build:empty": "ZETTLINK_BLOG_ALLOW_EMPTY_VAULT=1 astro build && pagefind --site dist",
    "test": "vitest run",
    "typecheck": "ZETTLINK_BLOG_ALLOW_EMPTY_VAULT=1 astro check"
  },
  "dependencies": {
    "astro": "^6.3.1",
    "gray-matter": "^4.0.3",
    "marked": "^18.0.3",
    "sanitize-html": "^2.17.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "^22.7.0",
    "@types/sanitize-html": "^2.16.1",
    "pagefind": "^1.5.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
